        //  final：路由最终出站。没有任何规则匹配时走 Final 出站（默认=PROXY）。
        //  安全策略：未知流量走代理是最安全的选择——宁可慢，不能泄露。
        "final": "Final",                                                      // 最终出站标签

        //  auto_detect_interface：自动检测活跃网络接口（WiFi/移动数据/以太网等）。
        //  接口切换时自动更新路由。移动设备（Android/iOS）必备。
        "auto_detect_interface": true,                                         // 自动检测网卡切换

        //  default_domain_resolver：路由默认域名解析器。
        //  当路由规则需要解析域名（如 domain_suffix 匹配需要 DNS 查询）时使用。
        //  选择 dns-udp（最基础可靠的 DNS）。
        "default_domain_resolver": "dns-udp"                                   // 路由默认 DNS
    },

    // ╔══════════════════════════════════════════════════════════════════════════════╗
    // ║               第 8 部分：experimental — 实验性功能                          ║
    // ╚══════════════════════════════════════════════════════════════════════════════╝
    //  实验性功能，可能在未来版本中变动或移除。包括缓存持久化、Clash API 兼容、调试。
    "experimental": {

        // --- cache_file：缓存持久化 ---
        {
            //  将 DNS 缓存和 FakeIP 映射保存到磁盘（SQLite 数据库）。
            //  重启 sing-box 后可恢复，避免连接中断。
            "cache_file": {
                "enabled": true,                                               // 启用缓存文件（强烈推荐）
                "path": "cache.db",                                            // 缓存文件路径（SQLite 格式）

                //  cache_id：缓存标识符。修改配置后若缓存不兼容，改此 ID 强制重建。
                //  ⚠️ 已修改为 my-singbox-cache-v2（原值 cinchov）
                "cache_id": "my-singbox-cache-v2",                             // ⚠️ 缓存 ID（已修改，原值 cinchov）

                "store_fakeip": true,                                          // 持久化存储 FakeIP 映射表
                "store_dns": true                                              // 持久化存储 DNS 缓存
            },

            // --- clash_api：Clash API 兼容层 ---
            //  提供与 Clash 兼容的 REST API，可使用 Clash 生态的 Web 管理面板
            //  （如 yacd、metacubexd、razord 等）。
            "clash_api": {
                //  API 监听地址和端口。浏览器打开 http://127.0.0.1:9095/ui 进入管理面板。
                //  ⚠️ 已修改为 9095（原值 9090）
                "external_controller": "127.0.0.1:9095",                       // ⚠️ Clash API 地址（已修改）

                //  external_ui：Web UI 静态文件目录名。
                //  sing-box 会在同目录下找 ui 文件夹，里面放 HTML/JS/CSS 文件。
                //  需要手动下载 yacd 或 metacubexd 发布包解压到此目录。
                "external_ui": "ui",                                           // Web UI 目录名

                "default_mode": "rule"                                         // 默认 Clash 模式：rule（规则分流）
            },

            // --- debug：调试与性能调优 ---
            "debug": {
                //  gc_percent：Go GC（垃圾回收）触发百分比。
                //  100 = 堆内存增长 100% 时触发 GC（Go 默认值）。
                //  调低：减少内存占用但增加 CPU。调高：反之。代理场景默认即可。
                "gc_percent": 100,                                             // GC 触发百分比

                //  memory_limit：内存软限制 400MB。
                //  sing-box 尽量将内存控制在此范围内。非硬限制，极端情况可能超出。
                //  常规使用（非服务器级大流量）400MB 足够。
                //  大量并发连接（>1000）可能需要调高。
                "memory_limit": "400MB"                                        // 内存限制 400MB
            }
        }
    }

