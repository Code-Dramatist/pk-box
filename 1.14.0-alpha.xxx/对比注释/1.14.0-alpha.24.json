                //  ⚠️ 已修改（原值 /sba-vl）
                "path": "/ws-proxy-path",                                      // ⚠️ WS 路径（已修改）
                "headers": {
                    //  ⚠️ 已修改（原值 pk1.372164885.xyz）
                    "Host": "node2.example-proxy.net"                          // ⚠️ Host 头（已修改）
                },
                "max_early_data": 2560,                                         // 最大早期数据 2560 字节
                "early_data_header_name": "Sec-WebSocket-Protocol"             // 早期数据伪装头
