    ],

    // ╔══════════════════════════════════════════════════════════════════════════════╗
    // ║                   第 7 部分：route — 路由配置（核心）                       ║
    // ╚══════════════════════════════════════════════════════════════════════════════╝
    //  路由决定了每一条流量（按域名/IP/协议/应用等匹配）走哪个出站。
    //  规则按顺序从上到下匹配，第一条命中即停止。
    "route": {

        // ---------------------------------------------------------------------------
        //  rules — 路由规则列表
        // ---------------------------------------------------------------------------
        "rules": [

            // --- 规则 0：sniff — 嗅探流量中的域名 ---
            //  这是最关键的第一条规则！没有匹配条件 = 匹配所有流量。
            //  sniff 动作：sing-box 尝试从流量中提取域名（从 TLS SNI / HTTP Host / DNS 查询等）。
            //  没有嗅探就没有域名分流——后续所有按域名的规则都依赖此规则。
            {
                "action": "sniff"                                              // 嗅探动作（提取域名信息）
            },

            // --- 规则 1：劫持 DNS 流量到内置 DNS 服务器 ---
            //  logical 类型：组合多个子规则，"or"=任一匹配即命中。
            {
                "type": "logical",                                             // 规则类型：逻辑组合
                "mode": "or",                                                  // 组合模式：或（任一子规则命中）
                "rules": [
                    {
                        "port": 53                                             // 子规则 1：目标端口 53（DNS 标准端口）
                    },
                    {
                        "protocol": "dns"                                      // 子规则 2：流量被协议识别为 DNS
                    }
                ],
                //  hijack-dns：将匹配的流量重定向到内置 DNS 服务器，由 dns 模块处理。
                //  这是 DNS 防污染的关键——DNS 流量不直接转发到出站，而是被 sing-box 接管。
                "action": "hijack-dns"                                         // 劫持到内置 DNS
            },

            // --- 规则 2：哔哩哔哩 → 直连 ---
            {
                "domain_suffix": [
                    "api.bilibili.com",                                        // B站 API
                    "www.bilibili.com",                                        // B站 主站
                    "bilivideo.com",                                           // B站 视频 CDN
                    "hdslb.com",                                               // B站 短域名
                    "bilicdn1.com",                                            // B站 CDN #1
                    "bilicdn.com"                                              // B站 CDN 通用域名
                ],
                "outbound": "DIRECT"                                           // 直连（国内视频 CDN 直连速度最快）
            },

            // --- 规则 3：国内社交/短视频 → 直连 ---
            {
                "domain_suffix": [
                    "xiaohongshu.com",                                          // 小红书
                    "xhscdn.com",                                              // 小红书 CDN
                    "kuaishou.com",                                            // 快手
                    "ixigua.com"                                               // 西瓜视频（字节跳动）
                ],
                "outbound": "DIRECT"                                           // 直连
            },

            // --- 规则 4：FakeIP 地址段 → 代理 ---
            //  FakeIP 机制的核心路由规则！所有 FakeIP（198.18.0.0/15）的流量都必须走代理。
            {
                "ip_cidr": "198.18.0.0/15",                                    // FakeIP 地址范围（与 dns.fakeip.inet4_range 一致）
                "outbound": "PROXY"                                            // 走代理
            },

            // --- 规则 5：route-options — 路由选项 ---
            {
                "action": "route-options",                                     // 动作：设置路由选项（不选出站）

                //  udp_disable_domain_unmapping：禁用 UDP 域名反向映射。
                //  FakeIP 的 UDP 包默认会尝试从映射表恢复域名。禁用后减少处理开销。
                //  疑惑：禁用会不会影响 UDP 应用（网游/语音）？
                //  回答：部分依赖域名的 UDP 应用可能受影响。如果遇到问题改 false。权衡：性能 vs 兼容。
                "udp_disable_domain_unmapping": true,                          // 禁用 UDP 域名反向映射

                //  udp_connect：启用 UDP 连接模式。
                //  将无连接 UDP 转为面向连接（类似 QUIC），更稳定且易于代理转发。
                "udp_connect": true                                            // 启用 UDP 连接模式
            },

            // --- 规则 6：广告/HTTPDNS → 静默丢弃 ---
            {
                "rule_set": [
                    "Ads",                                                     // 通用广告
                    "httpDNS",                                                 // HTTPDNS 服务（阻止绕过内置 DNS）
                    "DNSreject"                                                // DNS 层面应拒绝的域名
                ],
                "action": "reject",                                            // 动作：拒绝
                "method": "drop"                                               // 拒绝方式：drop=静默丢弃（不返回错误）
            },

            // --- 规则 7：Clash 全局模式 → 全部代理 ---
            {
                //  clash_mode：匹配 Clash API 中的模式设置。
                //  当用户在管理面板切换到 Global 模式时，此规则命中，所有流量走 PROXY。
                "clash_mode": "Global",                                        // Clash 模式：全局
                "outbound": "PROXY"                                            // 全部走代理
            },

            // --- 规则 8：Clash 直连模式 → 全部直连 ---
            {
                "clash_mode": "Direct",                                        // Clash 模式：直连
                "outbound": "DIRECT"                                           // 全部直连（临时关闭代理）
            },

            // --- 规则 9：Apple 服务 → 直连 ---
            {
                //  Apple 在国内有大量 CDN 节点（iCloud 云上贵州等），直连速度快。
                "rule_set": "Apple",                                           // Apple 规则集
                "outbound": "DIRECT"                                           // 直连
            },

            // --- 规则 10：YouTube / Google / Telegram 域名集 → 代理 ---
            {
                "rule_set": [
                    "geosite-youtube",                                         // YouTube 域名
                    "geosite-google",                                          // Google 域名
                    "telegram"                                                 // Telegram 域名
                ],
                "outbound": "PROXY"                                            // 走代理
            },

            // --- 规则 11：FCM 推送 + Android 系统服务 → 代理 ---
            {
                "rule_set": [
                    "fcm",                                                     // Google Firebase 消息推送
                    "Android"                                                  // Android 系统服务
                ],
                "outbound": "PROXY"                                            // 走代理（Google 服务在国内不稳定）
            },

            // --- 规则 12：Google 中国域名 → 代理 ---
            {
                //  google.cn / googleapis.cn 虽然理论上在中国可访问，
                //  但 DNS 经常被劫持，且翻译等服务不稳定。走代理更可靠。
                "domain_suffix": [
                    "google.cn",                                               // Google 中国搜索（已停止服务）
                    "googleapis.cn"                                            // Google API 中国站
                ],
                "outbound": "PROXY"                                            // 走代理
            },

            // --- 规则 13：国际流行服务 → 代理 ---
            {
                "domain_suffix": [
                    "netflix",                                                 // Netflix 流媒体
                    "spotify",                                                 // Spotify 音乐
                    "github",                                                  // GitHub 代码托管
                    "steam",                                                   // Steam 游戏商城
                    "discord",                                                 // Discord 语音/社区
                    "reddit",                                                  // Reddit 论坛
                    "tiktok",                                                  // TikTok 短视频
                    "twitter",                                                 // Twitter/X 社交
                    "facebook",                                                // Facebook 社交
                    "amazon",                                                  // Amazon 电商/云
                    "microsoft",                                               // Microsoft 服务
                    "apple",                                                   // Apple 服务
                    "paypal"                                                   // PayPal 支付
                ],
                "outbound": "PROXY"                                            // 走代理
            },

            // --- 规则 14：多规则集 → 代理（综合代理列表） ---
            {
                "rule_set": [
                    "telegram",                                                // Telegram 域名
                    "telegram_ip",                                             // Telegram IP（确保覆盖全面）
                    "geosite-youtube",                                         // YouTube
                    "instagram",                                               // Instagram
                    "Google",                                                  // Google（senshinya 源，注意大写 G）
                    "ai",                                                      // AI 服务（ChatGPT/Claude/Gemini 等）
                    "GlobalMedia",                                             // 全球流媒体
                    "Proxy",                                                   // 非中国域名（注意大写 P）
                    "gfw"                                                      // GFW 封锁列表
                ],
                "outbound": "PROXY"                                            // 走代理
            },

            // --- 规则 15：特定 APP（月星宝）→ 直连 ---
            {
                //  按 Android 应用包名匹配流量。
                "package_name": "com.wwwscn.yuexingbao",                       // 月星宝 APP 包名
                "outbound": "DIRECT"                                           // 直连
            },

            // --- 规则 16：特定 APP 正则 → 代理 ---
            {
                //  正则匹配多个应用包名：
                //  com.google.android.youtube = YouTube 官方
                //  com.google.android.apps.maps/docs/drive = Google 地图/文档/网盘
                //  app.revanced.android.youtube = YouTube ReVanced（魔改版）
                //  org.telegram.messenger(及子包) = Telegram
                //  符号含义：^开头 $结尾 |或 \\.转义点号 \\..*子包名后缀
                "package_name_regex": "^(com\\.google\\.android\\.(youtube|apps\\.(maps|docs|drive))|app\\.revanced\\.android\\.youtube|org\\.telegram\\.messenger(\\..*)?)$",
                "outbound": "PROXY"                                            // 走代理
            },

            // --- 规则 17：NTP + ICMP → 直连 ---
            {
                "protocol": [
                    "ntp",                                                     // 网络时间协议
                    "icmp"                                                     // ping 协议
                ],
                "outbound": "DIRECT"                                           // 直连
            },

            // --- 规则 18：特定服务 → 直连 ---
            {
                "domain_suffix": [
                    "sponsor.ajay.app",                                        // SponsorBlock（跳过 YouTube 赞助片段）
                    "ifbapp.com",                                              // 某国内 APP 服务
                    "allawnos.com",                                            // 某国内 APP 服务
                    "heytapmobi.com",                                          // OPPO/一加
                    "steamserver.net"                                          // Steam 服务器
                ],
                "outbound": "DIRECT"                                           // 直连
            },

            // --- 规则 19：拒绝 STUN/QUIC/DTLS 协议 ---
            {
                //  STUN：NAT 穿透协议（WebRTC 使用），可能泄露真实 IP。
                //  QUIC：HTTP/3 底层协议，基于 UDP，可能绕过代理。
                //  DTLS：UDP 上的 TLS（WebRTC 加密），可能泄露 IP。
                "protocol": [
                    "stun",                                                    // STUN（WebRTC NAT 穿透）
                    "quic",                                                    // QUIC（HTTP/3 底层）
                    "dtls"                                                     // DTLS（UDP 上 TLS）
                ],
                "action": "reject"                                             // 拒绝
                //  注意：拒绝 QUIC 会影响 HTTP/3 网站，但浏览器会回退到 HTTP/2（TCP），影响不大。
            },

            // --- 规则 20：拒绝特定跟踪/数据收集域名 ---
            {
                "domain": [
                    "beacon.qq.com",                                           // 腾讯数据上报信标
                    "abyss.cyapi.cn",                                          // 某数据收集 API
                    "ad.cyapi.cn",                                             // 某广告 API
                    "gather.colorfulclouds.net"                                // 彩云天气数据收集
                ],
                "action": "reject",                                            // 拒绝
                "method": "drop"                                               // 静默丢弃
            },

            // --- 规则 21：拒绝海外 IPv6 流量 ---
            {
                //  目的：IPv6 的 GFW 拦截弱于 IPv4，防止海外 IPv6 流量绕过代理。
                //  logical "and"：所有子规则必须同时满足才命中。
                "type": "logical",                                             // 逻辑规则
                "mode": "and",                                                 // 与模式（全部满足）
                "rules": [
                    {
                        "ip_version": 6                                        // 子规则 1：IPv6 流量
                    },
                    {
                        //  子规则 2：匹配全局单播 IPv6 地址...
                        "default_interface_address": "2000::/3",
                        "invert": true                                         // ‼️ 取反→匹配非全局单播地址（即中国 IPv6 段）
                    }
                ],
                //  合起来：IPv6 流量 且 非中国 IPv6 地址 → 拒绝。
                //  简单说：海外 IPv6 全部拒绝，强制走 IPv4 代理。
                "action": "reject"                                             // 拒绝海外 IPv6
            },

            // --- 规则 22：Google FCM 推送（特定端口）→ 代理 ---
            {
                "type": "logical",                                             // 逻辑规则
                "mode": "and",                                                 // 与模式
                "rules": [
                    {
                        //  子规则 1：匹配 FCM 推送域名（主 + 8 个备用共 9 个）。
                        "domain_suffix": [
                            "mtalk.google.com",                                // FCM 主域名
                            "alt1-mtalk.google.com",                           // 备用 #1
                            "alt2-mtalk.google.com",                           // 备用 #2
                            "alt3-mtalk.google.com",                           // 备用 #3
                            "alt4-mtalk.google.com",                           // 备用 #4
                            "alt5-mtalk.google.com",                           // 备用 #5
                            "alt6-mtalk.google.com",                           // 备用 #6
                            "alt7-mtalk.google.com",                           // 备用 #7
                            "alt8-mtalk.google.com"                            // 备用 #8
                        ]
                    },
                    {
                        //  子规则 2：同时满足端口是 443 或 5228。
                        "port": [
                            443,                                               // HTTPS 端口
                            5228                                               // FCM 专用端口
                        ]
                    }
                ],
                "outbound": "PROXY"                                            // 走代理（确保 Android 消息推送正常）
            },

            // --- 规则 23：代理规则集（第二轮）→ 代理 ---
            {
                //  注意 telegramip（没有下划线）和 telegram_ip（有下划线）是两个不同规则集！
                "rule_set": [
                    "telegramip",                                              // Telegram IP（DustinWin 源，无下划线）
                    "geosite-google",                                          // Google 域名
                    "proxy",                                                   // 代理域名（小写 p，不同于 Proxy）
                    "games",                                                   // 游戏
                    "ai"                                                       // AI
                ],
                "outbound": "PROXY"                                            // 走代理
            },

            // --- 规则 24：国内综合规则集 → 直连 ---
            {
                "rule_set": [
                    "private",                                                 // 私有/局域网
                    "cn",                                                      // 国内域名
                    "cnip",                                                    // 国内 IP 段
                    "microsoft-cn",                                            // 微软中国
                    "apple-cn",                                                // 苹果中国
                    "google-cn",                                               // Google 中国
                    "games-cn",                                                // 国内游戏
                    "networktest"                                              // 网络检测
                ],
                "outbound": "DIRECT"                                           // 直连
            },

            // --- 规则 25：国内厂商/服务域名 → 直连 ---
            {
                "domain_suffix": [
                    "alipay.com",                                              // 支付宝
                    "alicdn.com",                                              // 阿里 CDN
                    "aliyuncs.com",                                            // 阿里云 OSS
                    "qcloud.com",                                              // 腾讯云
                    "cloud.tencent.com",                                       // 腾讯云控制台
                    "mi.com",                                                  // 小米
                    "xiaomi.com",                                              // 小米国际站
                    "huawei.com",                                              // 华为
                    "vivo.com.cn",                                             // vivo
                    "oppo.com",                                                // OPPO
                    "coolapk.com",                                             // 酷安
                    "wps.cn",                                                  // WPS 办公
                    "biliapi.com"                                              // B站 API
                ],
                "outbound": "DIRECT"                                           // 直连
            },

            // --- 规则 26：全球媒体/代理规则集（第三轮兜底）→ 代理 ---
            {
                //  疑惑：为什么同样规则集出现多次？（规则10/14/23/26）
                //  回答：不是冗余。规则链中前面的规则可能被更精确的规则拦截（如国内域名直连），
                //        后面再出现是为了兜底——确保漏网之鱼仍然被代理。
                "rule_set": [
                    "geosite-google",                                          // Google
                    "geosite-youtube",                                         // YouTube
                    "instagram",                                               // Instagram
                    "telegram",                                                // Telegram
                    "GlobalMedia",                                             // 全球媒体
                    "gfw",                                                     // GFW 列表
                    "Proxy"                                                    // 非中国域名
                ],
                "outbound": "PROXY"                                            // 走代理
            },

            // --- 规则 27：拒绝私有/保留 IP 段 ---
            {
                //  这些 RFC 6890 规定的特殊地址段不应出现在代理流量中。
                //  出现意味着异常（可能是攻击或配置错误），直接拒绝。
                "ip_cidr": [
                    "0.0.0.0/8",                                               // "本网络"地址
                    "10.0.0.0/8",                                              // A 类私有地址
                    "127.0.0.0/8",                                             // 回环地址（localhost）
                    "169.254.0.0/16",                                          // 链路本地（APIPA 自动分配）
                    "172.16.0.0/12",                                           // B 类私有地址
                    "192.168.0.0/16",                                          // C 类私有地址（最常见局域网）
                    "224.0.0.0/4",                                             // 组播地址
                    "240.0.0.0/4"                                              // 保留地址（E 类）
                ],
                "action": "reject"                                             // 拒绝（防止内网 IP 经由代理泄露）
            },

            // --- 规则 28：微信/支付宝/网易云音乐 → 直连 ---
            {
                "package_name": [
                    "com.tencent.mm",                                          // 微信
                    "com.eg.android.AlipayGphone",                             // 支付宝
                    "com.netease.cloudmusic"                                   // 网易云音乐
                ],
                "outbound": "DIRECT"                                           // 直连
            },

            // --- 规则 29：广告规则集 → 路由层拒绝 ---
            {
                "rule_set": [
                    "geosite_adguard",                                         // AdGuard 广告规则集
                    "geosite-category-ads-all"                                 // 全量广告规则集
                ],
                "action": "reject"                                             // 拒绝
            },

            // --- 规则 30：拒绝 STUN/TURN/HTTPDNS 服务 ---
            {
                //  阻止 WebRTC 泄露真实 IP 和 HTTPDNS 绕过内置 DNS。
                //  ⚠️ 注意：这会破坏 WebRTC 功能（视频通话等）！
                //  如果你需要 Telegram/微信视频通话，请删除此规则。
                "type": "logical",                                             // 逻辑规则
                "mode": "or",                                                  // 或模式
                "rules": [
                    {
                        //  子规则 1：UDP 协议 + STUN/TURN 常用端口。
                        "network": "udp",                                      // UDP 协议
                        "port": [
                            3478,                                              // STUN 标准端口
                            5349,                                              // STUN over TLS
                            5350,                                              // STUN 端口
                            19302,                                             // Google STUN
                            10000                                              // TURN 常用端口
                        ]
                    },
                    {
                        "domain_regex": "^stun\\..+"                           // 子规则 2：以 stun. 开头的域名
                    },
                    {
                        "domain_keyword": [
                            "stun",                                            // 域名含 stun
                            "turn",                                            // 域名含 turn
                            "httpdns"                                          // 域名含 httpdns（阿里/腾讯 HTTPDNS）
                        ]
                    },
                    {
                        "protocol": "stun"                                     // 子规则 4：协议识别为 STUN
                    }
                ],
                "action": "reject"                                             // 拒绝
            },

            // --- 规则 31：反欺诈规则集 → 拒绝 ---
            {
                "rule_set": "anti_fraud",                                      // 反欺诈/反诈骗域名规则集
                "action": "reject"                                             // 拒绝（保护安全）
            },

            // --- 规则 32：私有 IP → 直连 ---
            {
                //  ip_is_private：匹配所有 RFC 1918 私有 IP 地址（10.x/172.16-31.x/192.168.x）。
                //  这条在规则 27（拒绝私有 IP）之后，因为规则 27 用 ip_cidr 手动列出了范围，
                //  这条用 ip_is_private 作为补充兜底（匹配规则 27 可能没覆盖到的私有 IP）。
                "ip_is_private": true,                                         // 匹配私有 IP
                "outbound": "DIRECT"                                           // 直连
            },

            // --- 规则 33：resolve — 强制 DNS 解析 ---
            {
                //  路由链的最后一步。对剩余未匹配流量中目标为域名的进行 DNS 解析，
                //  解析出 IP 后再根据 IP 规则路由。
                "action": "resolve"                                            // 强制解析域名
            }
        ],

        // ---------------------------------------------------------------------------
        //  rule_set — 远程规则集定义
        //  从远程 URL 下载 .srs 格式（sing-box rule set 二进制格式）的规则文件。
        //  每 48 小时自动更新一次。走 PROXY 出站下载（因为源站大多在 GitHub）。
        // ---------------------------------------------------------------------------
        "rule_set": [

            // --- 规则集：geosite-category-ads-all（全量广告分类） ---
            {
                "type": "remote",                                              // 类型：远程下载
                "tag": "geosite-category-ads-all",                             // 标签名
                //  SagerNet/sing-geosite = sing-box 社区维护的 geosite 规则集仓库。
                //  category-ads-all.srs = 所有广告分类合集。
                "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-category-ads-all.srs",
                "http_client": "default",                                      // 使用 default HTTP 客户端（走 PROXY）
                "update_interval": "48h0m0s"                                   // 更新间隔 48 小时
            },

            // --- 规则集：geosite_adguard（AdGuard 广告过滤器） ---
            {
                "type": "remote",                                              // 远程下载
                "tag": "geosite_adguard",                                      // 标签名
                //  217heidai/adblockfilters = 社区维护的 AdGuard 规则转 sing-box 格式。
                "url": "https://cdn.jsdelivr.net/gh/217heidai/adblockfilters@main/rules/adblocksingbox.srs",
                "http_client": "default",                                      // 默认 HTTP 客户端
                "update_interval": "48h0m0s"                                   // 48 小时
            },

            // --- 规则集：geosite-google（Google 服务） ---
            {
                "type": "remote",                                              // 远程下载
                "tag": "geosite-google",                                       // 标签名
                //  Google 所有服务域名：搜索/Gmail/地图/分析/广告/API/云平台等。
