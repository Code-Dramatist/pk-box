      {
        // 规则作用：微软域名导入 🪟 微软 策略组。
        // 只匹配 microsoft.com，包括所有子域名。
        "domain_suffix": "microsoft.com",
        "outbound": "🪟 微软"
      },
      {
        // 规则作用：代理、GFW、AI、游戏、全球媒体等规则集直接导入 📦 sing-box 代理。
        // 这些规则集包含大量被封锁或需要代理的域名，统一走代理出口。
        // 包括：geosite-geolocation-!cn (非中国地区域名)、GFW 列表、
        //       AI 服务 (ChatGPT、Claude 等)、游戏平台、全球媒体娱乐。
        "rule_set": [
          "Proxy",
          "gfw",
          "ai",
          "games",
          "GlobalMedia",
          "proxy"
        ],
        "outbound": "📦 sing-box"
      },
      {
        // 规则作用：Clash 模式为 Global 时，全部流量走 🌐 全局 策略组。
        // 这是为了兼容 Clash API，让 GUI 客户端可以切换到"全局模式"。
        "clash_mode": "Global",
        "outbound": "🌐 全局"
      },
      {
        // 规则作用：FakeIP 地址池 (198.18.0.0/15) 的流量强制走代理。
        // 因为这些 FakeIP 本身就是虚拟的，只有 sing-box 知道它们对应什么域名，
        // 必须走代理出口，sing-box 才能在出口处还原真实的连接目标。
        "ip_cidr": "198.18.0.0/15",
        "outbound": "📦 sing-box"
      },
      {
        // 规则作用：FakeIP IPv6 地址池 (fc00::/18) 的流量强制走代理。
        "ip_cidr": "fc00::/18",
        "outbound": "📦 sing-box"
      },
      {
        // 规则作用：NTP (时间同步) 和 ICMP (ping) 协议走直连。
