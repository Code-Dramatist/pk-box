          "bytecdn.com",        // 字节跳动 CDN
          "snssdk.com",         // 字节跳动社交 SDK
          "bytedance.com",      // 字节跳动
          "toutiao.com",        // 今日头条
          "volcengine.com",     // 火山引擎
          "yximgs.com",         // 快手图片
          "gtimg.com",          // 腾讯图片 CDN
          "360buyimg.com",      // 京东图片 CDN
          "pinduoduo.com"       // 拼多多
        ],
        "outbound": "🇨🇳 国内流量"
      },
      {
        // 规则作用：国内常见应用包名导入 🇨🇳 国内流量。
        // 微信、支付宝、网易云音乐、月行宝等。
        // 应用包名路由比域名更精确，可以针对特定 App 制定策略。
        "package_name": [
          "com.tencent.mm",              // 微信
          "com.eg.android.AlipayGphone", // 支付宝
          "com.netease.cloudmusic",      // 网易云音乐
          "com.wwwscn.yuexingbao"        // 月行宝
        ],
        "outbound": "🇨🇳 国内流量"
      },
      {
        // 规则作用：苹果服务规则集导入 🍎 苹果 策略组。
        "rule_set": "Apple",
        "outbound": "🍎 苹果"
      },
      {
        // 规则作用：Clash 模式为 Direct 时，全部流量走 🇨🇳 国内流量 (即直连)。
        // 同样是为了兼容 Clash API 的"直连模式"。
        "clash_mode": "Direct",
        "outbound": "🇨🇳 国内流量"
      },
      {
        // 规则作用：Google 中国域名 (google.cn, googleapis.cn) 走 🇨🇳 国内流量。
        // 这些域名在国内有服务器，可以直连，速度快。
        "domain_suffix": [
          "google.cn",
          "googleapis.cn"
        ],
        "outbound": "🇨🇳 国内流量"
      },
      {
        // 规则作用：中国域名后缀走 🇨🇳 国内流量。
        // 包括 .cn、.中国 (.xn--fiqs8s)、.公司 (.xn--55qx5d)、.网络 (.xn--io0a7i)。
        // 这是最后一道国内流量保障，只要域名以这些结尾，就直连。
        "domain_suffix": [
          ".cn",
          ".xn--fiqs8s",
          ".xn--55qx5d",
          ".xn--io0a7i"
        ],
        "outbound": "🇨🇳 国内流量"
      },
      {
        // 规则作用：广告、HTTP DNS、DNS 拒绝规则集，直接丢弃。
        // 这些域名的连接请求不应发出，直接 drop，不消耗代理流量。
        "rule_set": [
          "Ads",
          "httpDNS",
          "DNSreject"
        ],
        "action": "reject",
        "method": "drop"
      },
      {
        // 规则作用：特定反追踪域名直接丢弃。
        // beacon.qq.com：腾讯数据灯塔 (用户行为追踪)
        // abyss.cyapi.cn、ad.cyapi.cn：彩云天气的广告和深渊 API
        // gather.colorfulclouds.net：彩云天气数据收集
        "domain": [
          "beacon.qq.com",
          "abyss.cyapi.cn",
          "ad.cyapi.cn",
          "gather.colorfulclouds.net"
        ],
        "action": "reject",
        "method": "drop"
      },
      {
        // 规则作用：反欺诈规则集，拒绝连接。
        // 匹配钓鱼、诈骗、恶意网站，直接拒绝，保护安全。
        "rule_set": "anti_fraud",
        "action": "reject"
      },
      {
        // 规则作用：拒绝 STUN 和 DTLS 协议。
        // STUN：WebRTC 使用的 NAT 穿透协议，可能泄露真实 IP。
        // DTLS：基于 UDP 的 TLS 加密，也是 WebRTC 的一部分。
        // 直接拒绝这些协议可以防止 WebRTC 泄露真实 IP。
        "protocol": [
          "stun",
          "dtls"
        ],
        "action": "reject"
      },
      {
        // 规则作用：拒绝 UDP 上的特定端口流量，以及域名含有关键字的连接。
        // 针对 WebRTC 和 HTTP DNS 进行全方位封堵。
        // 子规则 1：UDP 且端口为 3478 (STUN)、5349 (STUN over TLS)、
        //           5350 (STUN over TCP)、19302 (Google STUN)、10000 (TURN)。
        // 子规则 2：域名以 stun. 开头。
        // 子规则 3：域名包含 stun、turn、httpdns 关键字。
        // 三个子规则是 or 关系，命中任何一个就拒绝。
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "network": "udp",
            "port": [
              3478,
              5349,
              5350,
              19302,
              10000
            ]
          },
          {
            "domain_regex": "^stun\\..+"
          },
          {
            "domain_keyword": [
              "stun",
              "turn",
              "httpdns"
            ]
          }
        ],
        "action": "reject"
      },
      {
        // 规则作用：路由选项，调整底层连接行为。
        // 注意：这个规则的匹配范围是所有流量（没有限制条件），所以它对每条连接都生效。
        "action": "route-options",
        // 禁用 UDP 域名解映射 (UDP Disable Domain Unmapping)。
        // 什么是 UDP 域名解映射？
        // 答：某些代理协议在转发 UDP 时，会尝试从 UDP 载荷中提取域名，以便进行路由匹配。
        //     禁用后可以提高安全性，防止域名信息在 UDP 传输中被意外泄露。
        "udp_disable_domain_unmapping": true,
        // 启用 UDP 连接 (UDP Connect)。
        // 将 UDP 数据包封装成类似 TCP 连接的形态，代理转发更稳定。
        // 特别适合 QUIC、游戏 UDP 等长连接场景。
        "udp_connect": true
      },
      {
        // 规则作用：强制对所有连接进行 DNS 解析。
        // 这是路由规则的最后一条，确保所有连接在进入 final 之前都完成 DNS 解析。
        // 这样 final 出站 (🚦 最终) 才能根据 IP 或其他信息进行最终决策。
        "action": "resolve"
      }
    ],

    // ╔══════════════════════════════════════════════════════════════╗
    // ║                 规则集定义 (rule_set)                      ║
    // ║  从远程 URL 下载规则文件，定期更新。                       ║
    // ║  .srs 是 sing-box 的二进制规则格式，体积小加载快。        ║
    // ║  .json 是原始文本格式，解析稍慢但可读性高。                ║
    // ╚══════════════════════════════════════════════════════════════╝
    "rule_set": [
      {
