    // 🚦 最终 是一个选择器，用户可以根据需要切换全局行为。
    "final": "🚦 最终",
    // 自动检测默认网络接口。
    // 对于多网卡设备 (如有线和无线)，自动选择正在使用的主网卡。
    "auto_detect_interface": true,
    // 默认域名解析器：阿里 DNS QUIC。
    // 用于解析出站规则中未明确指定 domain_resolver 的域名。
