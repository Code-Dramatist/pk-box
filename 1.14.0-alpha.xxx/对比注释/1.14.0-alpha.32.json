          "api.bilibili.com",   // 哔哩哔哩 API
          "www.bilibili.com",   // 哔哩哔哩主站
          "bilivideo.com",      // 哔哩哔哩视频 CDN
          "hdslb.com",          // 哔哩哔哩 (旧域名)
          "bilicdn1.com",       // 哔哩哔哩 CDN
          "bilicdn.com",        // 哔哩哔哩 CDN
          "xiaohongshu.com",    // 小红书
          "xhscdn.com",         // 小红书 CDN
