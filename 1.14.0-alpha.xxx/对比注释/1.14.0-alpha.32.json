        // ICMP 走直连可以让 ping 命令正常工作，方便网络排障。
        "protocol": [
          "ntp",
          "icmp"
        ],
        "outbound": "DIRECT"
      },
      {
        // 规则作用：所有私有 IP (10.x、172.16.x、192.168.x 等) 走 🇨🇳 国内流量。
        // 局域网、公司内网、NAS、打印机等，都应该直连。
        "ip_is_private": true,
        "outbound": "🇨🇳 国内流量"
      },
      {
        // 规则作用：国内相关规则集全部导入 🇨🇳 国内流量。
        // 包括：私有地址、中国域名、中国 IP、微软中国 CDN、苹果中国 CDN、
        //       国内游戏、网络测试 (用于判断是否连通国内网络) 等。
        "rule_set": [
          "private",
          "cn",
          "cnip",
          "microsoft-cn",
          "apple-cn",
          "games-cn",
          "networktest"
        ],
        "outbound": "🇨🇳 国内流量"
      },
      {
        // 规则作用：大量国内主流服务域名导入 🇨🇳 国内流量。
