          "ifbapp.com",         // IFB 应用
          "allawnos.com",       // Allawnos
          "heytapmobi.com",     // OPPO/一加/realme 系统服务
          "steamserver.net",    // Steam 中国服务器
          "douyinvod.com",      // 抖音点播
          "ibytedtos.com",      // 字节跳动
