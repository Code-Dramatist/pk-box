  },

  // ╔══════════════════════════════════════════════════════════════╗
  // ║                   服务配置 (services)                       ║
  // ║  内置的服务，如 API 接口、仪表板等。                        ║
  // ╚══════════════════════════════════════════════════════════════╝
  "services": [
    {
      // API 服务，提供 RESTful 接口用于外部控制和管理。
      // 与 Clash API 兼容，可被常见的 GUI 客户端 (如 Clash Verge、MetaCubeX 等) 控制。
      "type": "api",
      "tag": "api",
      // 监听地址：127.0.0.1 表示仅本机可访问。
      // 不要改成 0.0.0.0，否则局域网内其他设备也能控制你的代理，不安全。
      "listen": "127.0.0.1",
      // 监听端口：9091。
      // 如果端口被占用，可以改为 9092、9093 等。
      "listen_port": 9091,
      // 允许来自私有网络的请求。
      // 如果你的 GUI 客户端在同一台机器上，这个选项可开可不开。
      // 如果你的 GUI 在另一台设备上 (如路由器运行 sing-box，PC 上控制)，则必须开启。
      "access_control_allow_private_network": true,
      // 启用内置仪表板。
      // 访问 http://127.0.0.1:9091 可以看到一个简单的 Web 管理页面。
      "dashboard": true
    }
  ],

  // ╔══════════════════════════════════════════════════════════════╗
  // ║               实验性功能 (experimental)                     ║
  // ║  这些功能可能不够稳定，但能提供额外的性能优化。             ║
  // ╚══════════════════════════════════════════════════════════════╝
  "experimental": {
    // 缓存文件配置。
    // 用于持久化存储 FakeIP 映射、DNS 缓存、规则集缓存等数据。
    // 重启 sing-box 后，这些缓存仍然有效，避免冷启动时全部重新查询。
    "cache_file": {
      "enabled": true,
      // 缓存文件路径。可以改为绝对路径如 "/var/lib/sing-box/cache.db"。
      "path": "cache.db",
      // 存储 FakeIP 映射关系。
      // 这样重启后，旧的 FakeIP 仍然能对应到正确的域名，连接不会中断。
      "store_fakeip": true
    },
    // 调试与性能调优配置。
    "debug": {
      // 垃圾回收 (GC) 百分比。
      // 100 是 Go 语言的默认值。调大可以降低 GC 频率 (减少 CPU 占用)，
      // 但会占用更多内存。调小则相反。400MB 内存限制下，100 是比较平衡的设置。
      "gc_percent": 100,
      // 内存软限制：400MB。
      // 当内存使用接近这个值时，Go 的 GC 会更积极地回收内存。
      // 设置在 400MB 对大多数场景足够，避免内存泄漏导致系统 OOM。
      "memory_limit": "400MB"
    }
  }
}

/**
 * ╔══════════════════════════════════════════════════════════════════╗
 * ║                      📋 完整总结文档                            ║
 * ╚══════════════════════════════════════════════════════════════════╝
 *
 * 【这是什么？】
 * 这是一个面向中国大陆用户的 sing-box 核心配置文件 (config.json)。
 * sing-box 是一个高性能的通用代理工具，支持多种协议和灵活的路由规则。
 *
 * 【它能做什么？】
 * 1. 接管系统所有网络流量 (通过 TUN 虚拟网卡)。
 * 2. 智能分流国内外流量：
 *    - 国内网站：直连，速度快。
 *    - 国外网站：走代理，突破封锁。
 * 3. 过滤广告：在 DNS 层面和路由层面双重屏蔽广告域名。
 * 4. 防止泄露：阻止 WebRTC STUN/TURN、防止 DNS 泄露。
 * 5. 优化速度：
 *    - FakeIP 技术减少 DNS 解析延迟。
 *    - 多 DNS 服务器分流，各取所长。
 *    - URL 测速自动选择最快节点。
 * 6. 应用识别：根据 Android 包名进行精确路由。
 * 7. 时间同步：内置 NTP 客户端确保系统时间准确。
 *
 * 【设计哲学】
 * - 国内优先直连：凡是国内能访问的，尽量直连，节省代理流量，降低延迟。
 * - DNS 精准分流：不同域名用不同的 DNS 服务器，兼顾速度和准确性。
 * - 安全第一：防泄露、防欺诈、防广告，不因为代理而引入新的风险。
 * - 用户可控制：通过多个 selector 策略组，用户可以在 GUI 中随时调整策略。
 * - 定期更新：规则集每 48 小时自动更新，保持域名库新鲜。
 *
 * 【使用步骤】
 * 1. 安装 sing-box (下载对应平台的二进制文件)。
 * 2. 将本配置保存为 config.json。
 * 3. 【重要】在 outbounds 数组中添加你的代理节点配置。
 * 4. 【重要】将配置中所有的 "节点名称" 替换为你实际节点的 tag。
 * 5. 运行 sing-box run -c config.json。
 * 6. (可选) 使用 Clash Verge 等 GUI 客户端连接 API (127.0.0.1:9091) 进行可视化管理。
 *
 * 【常见问题 FAQ】
 * Q: 为什么有些网站打不开？
 * A: 可能是 DNS 解析失败。检查 DNS 规则是否匹配正确，尝试在 DNS 规则中增加该域名。
 *
 * Q: 为什么代理速度很慢？
 * A: 检查 urltest 的测试 URL 是否可访问，节点是否配置正确。
 *
 * Q: 为什么手机收不到通知？
 * A: 可能是 FCM 推送被阻断。检查 hosts_fix 中的 mtalk IP 是否最新，以及 📬 谷歌推送 是否走代理。
 *
 * Q: 为什么某些应用闪退？
 * A: 可能是 TUN 模式与该应用冲突。尝试将该应用包名加入 🇨🇳 国内流量 直连。
 *
 * Q: 为什么 Google Play 下载很慢？
 * A: 检查 dl.google.com 的 hosts 映射 IP 是否适合你的网络，以及是否走了 Google DNS 解析。
 *
 * Q: 如何确认代理没有泄露真实 IP？
 * A: 访问 browserleaks.com 或 ipleak.net，检查显示的 IP 是否是代理 IP。
 *
 * Q: FakeIP 地址池 (198.18.0.0/15) 与我现有网络冲突怎么办？
 * A: 可以修改 inet4_range 为其他未使用的保留地址段，如 198.51.100.0/24 (TEST-NET-2)。
 *
 * 【维护建议】
 * - 每月检查一次 hosts_fix 中的 IP 是否仍然有效 (特别是 FCM mtalk IP)。
 * - 关注规则集作者的更新，如果某个规则集停更了，及时更换。
 * - 定期查看 sing-box 日志，发现并解决潜在问题。
 * - 备份 config.json，方便重装或迁移。
 *
 * 【参考资源】
 * - sing-box 官方文档：https://sing-box.sagernet.org/
