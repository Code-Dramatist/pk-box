// ════════════════════════════════════════════════════════
// 【第八章】experimental — 实验性功能配置
// 包含 Clash API 兼容层 和 调试/内存控制
// ════════════════════════════════════════════════════════

  "experimental": {

    // ── Clash API 兼容层 ────────────────────────────────────────────────────
    // 提供与 Clash 兼容的 RESTful API，允许使用 Clash Dashboard 管理 sing-box
    // 常用 Dashboard：
    //   - Yacd：http://yacd.haishan.me
    //   - MetaCubeXD：http://metacubexd.pages.dev
    //   - 直接访问 http://127.0.0.1:9090/ui（需要提前下载 ui 文件夹）
    "clash_api": {
      // 控制器监听地址和端口
      // 127.0.0.1:9090 = 仅本机可访问，安全
      // 如果要局域网访问，改为 0.0.0.0:9090（注意安全风险）
      "external_controller": "127.0.0.1:9090",

      // Web UI 目录：sing-box 会从这个目录提供 HTTP 服务
      // "ui" 表示相对路径，即 sing-box 配置目录下的 ui/ 文件夹
      // 需要手动下载 Dashboard 前端文件到此目录
      "external_ui": "ui",

      // 默认 Clash 模式："rule"（按规则路由）
      // 可选：rule / global / direct
      // rule = 按 route.rules 路由（正常使用模式）
      // global = 全部走 PROXY（临时翻墙全开）
      // direct = 全部直连（临时关闭代理）
      "default_mode": "rule"
    },

    // ── 调试/内存配置 ────────────────────────────────────────────────────────
    "debug": {
      // GC 百分比：控制 Go 运行时垃圾回收触发阈值
      // 100 = 当内存使用量增长到上次GC后的 100% 时触发GC（默认值）
      // 降低此值（如50）会更频繁GC（内存占用低，但CPU消耗高）
      // 提高此值（如200）会减少GC频率（内存占用高，CPU消耗低）
      "gc_percent": 100,

      // 内存上限：400MB
      // 当 Go 运行时内存使用超过此值，会强制触发GC
      // 防止 sing-box 内存泄漏或规则集过大导致 OOM（内存溢出）
      // 疑惑：在内存充裕的设备（PC/NAS）上可以适当增大（如 800MB）
      //       在路由器/嵌入式设备上应根据实际可用内存调小
      "memory_limit": "400MB"
    }

  } // experimental 结束

}

// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║                         📋 配置总结 & 核心设计思路                            ║
// ╠══════════════════════════════════════════════════════════════════════════════╣
// ║                                                                              ║
// ║  【流量处理流程】                                                              ║
// ║  设备发出请求                                                                 ║
// ║    ↓ TUN 接口捕获（所有TCP/UDP）                                               ║
// ║    ↓ 协议嗅探（识别DNS/QUIC/HTTP等）                                           ║
// ║    ↓ DNS 查询劫持 → sing-box DNS 分流                                          ║
// ║      ↓ 国内域名 → alidns-quic/dnspub-doh（直连）                               ║
// ║      ↓ 境外域名 → fakeip（假IP）/ ggdns（Google专用）                           ║
// ║      ↓ 广告域名 → NOERROR空响应（拦截）                                         ║
// ║    ↓ 路由规则匹配                                                              ║
// ║      ↓ 广告/恶意 → REJECT-DROP（丢弃）                                         ║
// ║      ↓ 国内IP/域名 → DIRECT（直连+国内DNS）                                     ║
// ║      ↓ FakeIP段 → PROXY（查映射表 → 代理远端解析 → 建立真实连接）                  ║
// ║      ↓ 境外域名/规则集 → PROXY（选速度/稳定组）                                   ║
// ║      ↓ QUIC境外 → 🟣 QUIC-UDP（UDP专用节点）                                   ║
// ║      ↓ 未命中 → Final → PROXY（兜底代理）                                       ║
// ║                                                                              ║
// ║  【DNS 防污染原理（FakeIP核心）】                                                ║
// ║  正常DNS：客户端请求 google.com → 国内DNS返回被污染的假IP → 连接失败              ║
// ║  FakeIP：  客户端请求 google.com → fakeip返回 198.18.x.x（假IP）                ║
// ║           → 客户端向 198.18.x.x 发起 TCP 连接                                   ║
// ║           → TUN 捕获到目标是 FakeIP 段                                          ║
// ║           → reverse_mapping 还原为 google.com                                  ║
// ║           → 代理节点在境外解析 google.com → 获得真实IP → 建立连接                  ║
// ║                                                                              ║
// ║  【主要疑惑点汇总】                                                             ║
// ║  Q1: hosts_fix 为何必须？                                                      ║
// ║      A: 防止 DNS 服务器的域名解析形成循环依赖（自举死锁）                           ║
// ║  Q2: 同一域名在 DNS 和路由规则中都出现是否冗余？                                   ║
// ║      A: DNS层决定"解析成什么IP"，路由层决定"流量走哪个出站"，不冗余                 ║
// ║  Q3: FakeIP vs 真实DNS代理的区别？                                              ║
// ║      A: FakeIP本地不查真实IP，在代理端解析，彻底绕过DNS污染；真实DNS可能被污染     ║
// ║  Q4: 为何要拒绝 QUIC 然后又要特殊处理 QUIC？                                     ║
// ║      A: Google Play的QUIC走代理不稳定（丢弃降级TCP），其他QUIC用专用UDP节点        ║
// ║  Q5: 规则集更新间隔 48h 是否合理？                                               ║
// ║      A: 广告域名变化不频繁，48h足够；GFW列表变化快，可改为 24h                    ║
// ║                                                                              ║
// ╚══════════════════════════════════════════════════════════════════════════════╝
